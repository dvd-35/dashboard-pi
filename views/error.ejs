<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= code %> — Dashboard Pi</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #0d1117;
      color: #e6edf3;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .container { text-align: center; max-width: 400px; }
    .code { font-size: 5rem; font-weight: 800; color: #30363d; }
    .title { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; }
    .message { color: #8b949e; font-size: 0.875rem; margin-bottom: 2rem; }
    a { color: #58a6ff; text-decoration: none; }
    a:hover { text-decoration: underline; }
    pre { text-align: left; background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 1rem; font-size: 0.75rem; color: #8b949e; overflow: auto; margin-top: 1rem; }
  </style>
</head>
<body>
  <div class="container">
    <div class="code"><%= code %></div>
    <div class="title"><%= title %></div>
    <div class="message"><%= message %></div>
    <a href="/dashboard">← Retour au dashboard</a>
    <% if (stack) { %><pre><%= stack %></pre><% } %>
  </div>
</body>
</html>
