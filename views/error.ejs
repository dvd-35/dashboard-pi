<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= locals.code || 500 %> — Dashboard Pi</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #0d1117;
      color: #e6edf3;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .container { text-align: center; max-width: 500px; }
    .code { font-size: 5rem; font-weight: 800; color: #30363d; line-height: 1; }
    .title { font-size: 1.25rem; font-weight: 600; margin: 1rem 0 0.5rem; }
    .message { color: #8b949e; font-size: 0.875rem; margin-bottom: 2rem; }
    a { color: #58a6ff; text-decoration: none; }
    a:hover { text-decoration: underline; }
    pre {
      text-align: left;
      background: #161b22;
      border: 1px solid #30363d;
      border-radius: 8px;
      padding: 1rem;
      font-size: 0.75rem;
      color: #8b949e;
      overflow: auto;
      margin-top: 1.5rem;
      max-height: 300px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="code"><%= locals.code || 500 %></div>
    <div class="title"><%= locals.title || 'Erreur' %></div>
    <div class="message"><%= locals.message || 'Une erreur est survenue.' %></div>
    <a href="/dashboard">← Retour au dashboard</a>
    <% if (locals.stack) { %>
    <pre><%= stack %></pre>
    <% } %>
  </div>
</body>
</html>
