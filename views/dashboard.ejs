<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Dashboard — Pi</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d1117;
      --surface: #161b22;
      --surface2: #1c2128;
      --border: #30363d;
      --text: #e6edf3;
      --text-muted: #8b949e;
      --accent: #58a6ff;
      --accent2: #a371f7;
      --success: #3fb950;
      --warning: #d29922;
      --danger: #f85149;
      --sidebar-w: 220px;
    }

    html, body {
      height: 100%;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 0.9375rem;
    }

    /* ============ LAYOUT ============ */
    .app {
      display: flex;
      height: 100vh;
      overflow: hidden;
    }

    /* ============ SIDEBAR ============ */
    .sidebar {
      width: var(--sidebar-w);
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      overflow-y: auto;
    }

    .sidebar-logo {
      padding: 1.25rem 1rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 0.625rem;
    }

    .sidebar-logo .icon {
      width: 32px;
      height: 32px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }

    .sidebar-logo span {
      font-weight: 700;
      font-size: 0.9375rem;
      color: var(--text);
    }

    .sidebar-nav {
      padding: 0.75rem 0.5rem;
      flex: 1;
    }

    .nav-section {
      margin-bottom: 1.25rem;
    }

    .nav-label {
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #484f58;
      padding: 0 0.625rem;
      margin-bottom: 0.375rem;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.5rem 0.75rem;
      border-radius: 6px;
      cursor: pointer;
      transition: background 0.1s;
      color: var(--text-muted);
      font-size: 0.875rem;
      border: none;
      background: none;
      width: 100%;
      text-align: left;
    }

    .nav-item:hover { background: var(--surface2); color: var(--text); }
    .nav-item.active { background: rgba(88,166,255,0.1); color: var(--accent); }
    .nav-item .nav-icon { font-size: 1rem; width: 20px; text-align: center; flex-shrink: 0; }

    .sidebar-footer {
      padding: 0.75rem 0.5rem;
      border-top: 1px solid var(--border);
    }

    .user-info {
      padding: 0.5rem 0.75rem;
      margin-bottom: 0.5rem;
    }

    .user-name {
      font-size: 0.875rem;
      font-weight: 600;
    }

    .user-role {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    /* ============ MAIN ============ */
    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .topbar {
      padding: 0.75rem 1.5rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--surface);
      flex-shrink: 0;
    }

    .topbar-title {
      font-size: 1rem;
      font-weight: 600;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .time-display {
      font-size: 0.875rem;
      color: var(--text-muted);
      font-variant-numeric: tabular-nums;
    }

    .logout-btn {
      padding: 0.375rem 0.875rem;
      background: none;
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-muted);
      font-size: 0.8125rem;
      cursor: pointer;
      transition: all 0.15s;
    }

    .logout-btn:hover {
      border-color: var(--danger);
      color: var(--danger);
    }

    /* ============ CONTENT ============ */
    .content {
      flex: 1;
      overflow-y: auto;
      padding: 1.5rem;
    }

    /* ============ PANELS (sections) ============ */
    .panel {
      display: none;
    }

    .panel.active {
      display: block;
    }

    /* ============ OVERVIEW PANEL ============ */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem;
    }

    .stat-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.75rem;
    }

    .stat-label {
      font-size: 0.8125rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    .stat-icon {
      font-size: 1.125rem;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }

    .stat-sub {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 0.25rem;
    }

    .progress-bar {
      height: 4px;
      background: var(--border);
      border-radius: 2px;
      margin-top: 0.75rem;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      border-radius: 2px;
      transition: width 0.5s ease;
    }

    .progress-low    { background: var(--success); }
    .progress-medium { background: var(--warning); }
    .progress-high   { background: var(--danger); }

    /* ============ NOTES PANEL ============ */
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1rem;
    }

    .section-title {
      font-size: 1rem;
      font-weight: 600;
    }

    .btn {
      padding: 0.4375rem 0.875rem;
      border-radius: 6px;
      font-size: 0.8125rem;
      font-weight: 500;
      cursor: pointer;
      border: none;
      transition: all 0.15s;
    }

    .btn-primary {
      background: var(--accent);
      color: #0d1117;
    }

    .btn-primary:hover { background: #79c0ff; }

    .btn-ghost {
      background: none;
      border: 1px solid var(--border);
      color: var(--text-muted);
    }

    .btn-ghost:hover { border-color: var(--text-muted); color: var(--text); }

    .btn-danger {
      background: none;
      border: 1px solid transparent;
      color: var(--text-muted);
      padding: 0.25rem 0.5rem;
      font-size: 0.75rem;
    }

    .btn-danger:hover { color: var(--danger); border-color: var(--danger); }

    .notes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1rem;
    }

    .note-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem;
      cursor: pointer;
      transition: border-color 0.15s;
      position: relative;
    }

    .note-card:hover { border-color: var(--accent); }

    .note-title {
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text);
    }

    .note-preview {
      font-size: 0.8125rem;
      color: var(--text-muted);
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .note-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 0.75rem;
      padding-top: 0.75rem;
      border-top: 1px solid var(--border);
    }

    .note-date {
      font-size: 0.75rem;
      color: #484f58;
    }

    /* ============ BOOKMARKS PANEL ============ */
    .bookmarks-list {
      display: grid;
      gap: 0.5rem;
    }

    .bookmark-item {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      padding: 0.75rem 1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.15s;
      group: true;
    }

    .bookmark-item:hover { border-color: var(--accent); }

    .bookmark-favicon {
      width: 20px;
      height: 20px;
      border-radius: 4px;
      flex-shrink: 0;
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
    }

    .bookmark-info { flex: 1; min-width: 0; }

    .bookmark-title {
      font-size: 0.875rem;
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .bookmark-url {
      font-size: 0.75rem;
      color: var(--text-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .bookmark-category {
      font-size: 0.6875rem;
      padding: 0.125rem 0.5rem;
      background: rgba(88,166,255,0.1);
      color: var(--accent);
      border-radius: 4px;
      white-space: nowrap;
    }

    .bookmark-actions {
      opacity: 0;
      transition: opacity 0.15s;
    }

    .bookmark-item:hover .bookmark-actions { opacity: 1; }

    /* ============ MODAL ============ */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(4px);
      z-index: 100;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .modal-overlay.open { display: flex; }

    .modal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      width: 100%;
      max-width: 500px;
      box-shadow: 0 24px 64px rgba(0,0,0,0.5);
    }

    .modal-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 1.25rem;
    }

    .form-group { margin-bottom: 1rem; }

    .form-label {
      display: block;
      font-size: 0.8125rem;
      color: var(--text-muted);
      margin-bottom: 0.375rem;
      font-weight: 500;
    }

    .form-input, .form-textarea {
      width: 100%;
      padding: 0.5rem 0.75rem;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }

    .form-input:focus, .form-textarea:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(88,166,255,0.1);
    }

    .form-textarea {
      min-height: 120px;
      resize: vertical;
      font-family: inherit;
    }

    .modal-actions {
      display: flex;
      gap: 0.5rem;
      justify-content: flex-end;
      margin-top: 1.25rem;
    }

    /* ============ EMPTY STATE ============ */
    .empty-state {
      text-align: center;
      padding: 3rem;
      color: var(--text-muted);
    }

    .empty-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
    .empty-text { font-size: 0.875rem; }

    /* ============ TOAST ============ */
    .toast-container {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 200;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .toast {
      padding: 0.75rem 1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 0.875rem;
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      animation: slideIn 0.2s ease;
    }

    .toast-success { border-color: var(--success); color: var(--success); }
    .toast-error { border-color: var(--danger); color: var(--danger); }

    @keyframes slideIn {
      from { transform: translateX(100%); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }

    /* ============ RESPONSIVE ============ */
    @media (max-width: 640px) {
      .sidebar {
        width: 60px;
      }
      .sidebar-logo span,
      .nav-item span:last-child,
      .nav-label,
      .user-info { display: none; }
      .content { padding: 1rem; }
    }
  </style>
</head>
<body>
<div class="app">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="icon">🖥️</div>
      <span>Dashboard Pi</span>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section">
        <div class="nav-label">Menu</div>
        <button class="nav-item active" onclick="showPanel('overview')">
          <span class="nav-icon">📊</span>
          <span>Vue d'ensemble</span>
        </button>
        <button class="nav-item" onclick="showPanel('notes')">
          <span class="nav-icon">📝</span>
          <span>Notes</span>
        </button>
        <button class="nav-item" onclick="showPanel('bookmarks')">
          <span class="nav-icon">🔖</span>
          <span>Bookmarks</span>
        </button>
        <button class="nav-item" onclick="showPanel('system')">
          <span class="nav-icon">⚙️</span>
          <span>Système</span>
        </button>
      </div>
    </nav>

    <div class="sidebar-footer">
      <div class="user-info">
        <div class="user-name"><%= user.username %></div>
        <div class="user-role">Administrateur</div>
      </div>
      <form method="POST" action="/logout">
        <button type="submit" class="nav-item" style="color: var(--text-muted)">
          <span class="nav-icon">🚪</span>
          <span>Déconnexion</span>
        </button>
      </form>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="main">
    <div class="topbar">
      <div class="topbar-title" id="panelTitle">Vue d'ensemble</div>
      <div class="topbar-right">
        <div class="time-display" id="clock"></div>
      </div>
    </div>

    <div class="content">

      <!-- OVERVIEW PANEL -->
      <div class="panel active" id="panel-overview">
        <div class="stats-grid" id="statsGrid">
          <!-- Rempli par JS -->
        </div>
      </div>

      <!-- NOTES PANEL -->
      <div class="panel" id="panel-notes">
        <div class="section-header">
          <div class="section-title">Mes notes</div>
          <button class="btn btn-primary" onclick="openNoteModal()">+ Nouvelle note</button>
        </div>
        <div class="notes-grid" id="notesGrid">
          <% if (notes.length === 0) { %>
          <div class="empty-state" style="grid-column:1/-1">
            <div class="empty-icon">📝</div>
            <div class="empty-text">Aucune note. Créez-en une !</div>
          </div>
          <% } %>
          <% notes.forEach(note => { %>
          <div class="note-card" onclick="openNoteModal('<%= note.id %>', '<%= note.title.replace(/'/g, \"\\\\'\\\" ) %>', `<%= note.content.replace(/`/g, '\\\\`') %>`)">
            <div class="note-title"><%= note.title %></div>
            <div class="note-preview"><%= note.content || 'Aucun contenu' %></div>
            <div class="note-footer">
              <span class="note-date"><%= new Date(note.updated_at).toLocaleDateString('fr-FR') %></span>
              <button class="btn btn-danger" onclick="deleteNote(event, '<%= note.id %>')">Supprimer</button>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- BOOKMARKS PANEL -->
      <div class="panel" id="panel-bookmarks">
        <div class="section-header">
          <div class="section-title">Bookmarks</div>
          <button class="btn btn-primary" onclick="openBookmarkModal()">+ Ajouter</button>
        </div>
        <div class="bookmarks-list" id="bookmarksList">
          <% if (bookmarks.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">🔖</div>
            <div class="empty-text">Aucun bookmark. Ajoutez-en un !</div>
          </div>
          <% } %>
          <% bookmarks.forEach(bm => { %>
          <a class="bookmark-item" href="<%= bm.url %>" target="_blank" rel="noopener noreferrer">
            <div class="bookmark-favicon">
              <img src="https://www.google.com/s2/favicons?domain=<%= new URL(bm.url).hostname %>" 
                   width="16" height="16" alt="" 
                   onerror="this.style.display='none'; this.parentElement.textContent='🔗'">
            </div>
            <div class="bookmark-info">
              <div class="bookmark-title"><%= bm.title %></div>
              <div class="bookmark-url"><%= bm.url %></div>
            </div>
            <span class="bookmark-category"><%= bm.category %></span>
            <div class="bookmark-actions">
              <button class="btn btn-danger" onclick="deleteBookmark(event, '<%= bm.id %>')">✕</button>
            </div>
          </a>
          <% }) %>
        </div>
      </div>

      <!-- SYSTEM PANEL -->
      <div class="panel" id="panel-system">
        <div class="section-header">
          <div class="section-title">Monitoring système</div>
          <button class="btn btn-ghost" onclick="refreshSystem()">↻ Actualiser</button>
        </div>
        <div class="stats-grid" id="systemGrid">
          <!-- Rempli par JS -->
        </div>
      </div>

    </div><!-- /content -->
  </main>
</div>

<!-- MODAL NOTE -->
<div class="modal-overlay" id="noteModal">
  <div class="modal">
    <div class="modal-title" id="noteModalTitle">Nouvelle note</div>
    <div class="form-group">
      <label class="form-label">Titre</label>
      <input type="text" class="form-input" id="noteTitle" maxlength="200" placeholder="Titre de la note">
    </div>
    <div class="form-group">
      <label class="form-label">Contenu</label>
      <textarea class="form-textarea" id="noteContent" maxlength="10000" placeholder="Votre note..."></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal('noteModal')">Annuler</button>
      <button class="btn btn-primary" onclick="saveNote()">Sauvegarder</button>
    </div>
  </div>
</div>

<!-- MODAL BOOKMARK -->
<div class="modal-overlay" id="bookmarkModal">
  <div class="modal">
    <div class="modal-title">Nouveau bookmark</div>
    <div class="form-group">
      <label class="form-label">Titre</label>
      <input type="text" class="form-input" id="bmTitle" maxlength="200" placeholder="Mon site">
    </div>
    <div class="form-group">
      <label class="form-label">URL</label>
      <input type="url" class="form-input" id="bmUrl" placeholder="https://...">
    </div>
    <div class="form-group">
      <label class="form-label">Catégorie</label>
      <input type="text" class="form-input" id="bmCategory" maxlength="50" placeholder="Général">
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal('bookmarkModal')">Annuler</button>
      <button class="btn btn-primary" onclick="saveBookmark()">Ajouter</button>
    </div>
  </div>
</div>

<!-- TOASTS -->
<div class="toast-container" id="toasts"></div>

<script>
// ============ ÉTAT ============
let currentNoteId = null;
let systemData = null;

// ============ NAVIGATION ============
function showPanel(name) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  
  document.getElementById(`panel-${name}`).classList.add('active');
  event?.currentTarget?.classList.add('active');
  
  const titles = { overview: 'Vue d\'ensemble', notes: 'Notes', bookmarks: 'Bookmarks', system: 'Système' };
  document.getElementById('panelTitle').textContent = titles[name] || name;
  
  if (name === 'overview' || name === 'system') refreshSystem();
}

// ============ HORLOGE ============
function updateClock() {
  const now = new Date();
  document.getElementById('clock').textContent = now.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
}
setInterval(updateClock, 1000);
updateClock();

// ============ SYSTÈME ============
async function refreshSystem() {
  try {
    const res = await fetch('/api/system');
    const data = await res.json();
    if (data.success) {
      systemData = data.data;
      renderStats(data.data);
    }
  } catch (e) { console.error('Erreur système:', e); }
}

function getProgressClass(pct) {
  if (pct < 60) return 'progress-low';
  if (pct < 85) return 'progress-medium';
  return 'progress-high';
}

function renderStats(sys) {
  const html = [
    // CPU
    `<div class="stat-card">
      <div class="stat-header">
        <span class="stat-label">CPU</span>
        <span class="stat-icon">🔲</span>
      </div>
      <div class="stat-value">${sys.cpu.usage}%</div>
      <div class="stat-sub">${sys.cpu.cores} cœurs — charge: ${sys.cpu.loadAvg[0]}</div>
      <div class="progress-bar"><div class="progress-fill ${getProgressClass(sys.cpu.usage)}" style="width:${sys.cpu.usage}%"></div></div>
    </div>`,
    // RAM
    `<div class="stat-card">
      <div class="stat-header">
        <span class="stat-label">Mémoire</span>
        <span class="stat-icon">💾</span>
      </div>
      <div class="stat-value">${sys.memory.usagePercent}%</div>
      <div class="stat-sub">${sys.memory.used} / ${sys.memory.total}</div>
      <div class="progress-bar"><div class="progress-fill ${getProgressClass(sys.memory.usagePercent)}" style="width:${sys.memory.usagePercent}%"></div></div>
    </div>`,
    // Disque
    `<div class="stat-card">
      <div class="stat-header">
        <span class="stat-label">Disque</span>
        <span class="stat-icon">💿</span>
      </div>
      <div class="stat-value">${sys.disk.usagePercent}%</div>
      <div class="stat-sub">${sys.disk.used} / ${sys.disk.total} — libre: ${sys.disk.free}</div>
      <div class="progress-bar"><div class="progress-fill ${getProgressClass(sys.disk.usagePercent)}" style="width:${sys.disk.usagePercent}%"></div></div>
    </div>`,
    // Température
    sys.temperature ? `<div class="stat-card">
      <div class="stat-header">
        <span class="stat-label">Température</span>
        <span class="stat-icon">🌡️</span>
      </div>
      <div class="stat-value" style="color: ${sys.temperature > 75 ? 'var(--danger)' : sys.temperature > 60 ? 'var(--warning)' : 'var(--success)'}">${sys.temperature}°C</div>
      <div class="stat-sub">${sys.temperature > 75 ? '⚠️ Chauffe !' : sys.temperature > 60 ? 'Attention' : 'Normal'}</div>
    </div>` : '',
    // Uptime
    `<div class="stat-card">
      <div class="stat-header">
        <span class="stat-label">Uptime</span>
        <span class="stat-icon">⏱️</span>
      </div>
      <div class="stat-value" style="font-size:1.1rem">${sys.uptime.formatted}</div>
      <div class="stat-sub">${sys.hostname} · ${sys.arch}</div>
    </div>`,
    // Réseau
    ...(sys.network || []).map(n => `<div class="stat-card">
      <div class="stat-header">
        <span class="stat-label">${n.interface}</span>
        <span class="stat-icon">🌐</span>
      </div>
      <div class="stat-value" style="font-size:1rem">${n.ip}</div>
      <div class="stat-sub">Interface réseau</div>
    </div>`)
  ].join('');
  
  document.getElementById('statsGrid').innerHTML = html;
  document.getElementById('systemGrid').innerHTML = html;
}

// ============ NOTES ============
function openNoteModal(id = null, title = '', content = '') {
  currentNoteId = id;
  document.getElementById('noteModalTitle').textContent = id ? 'Modifier la note' : 'Nouvelle note';
  document.getElementById('noteTitle').value = id ? title : '';
  document.getElementById('noteContent').value = id ? content : '';
  document.getElementById('noteModal').classList.add('open');
  document.getElementById('noteTitle').focus();
}

async function saveNote() {
  const title = document.getElementById('noteTitle').value.trim();
  const content = document.getElementById('noteContent').value.trim();
  if (!title) { toast('Le titre est requis', 'error'); return; }
  
  try {
    const method = currentNoteId ? 'PUT' : 'POST';
    const url = currentNoteId ? `/api/notes/${currentNoteId}` : '/api/notes';
    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title, content })
    });
    const data = await res.json();
    if (data.success) {
      toast(currentNoteId ? 'Note mise à jour' : 'Note créée', 'success');
      closeModal('noteModal');
      setTimeout(() => location.reload(), 500);
    } else {
      toast('Erreur lors de la sauvegarde', 'error');
    }
  } catch (e) { toast('Erreur réseau', 'error'); }
}

async function deleteNote(e, id) {
  e.stopPropagation();
  if (!confirm('Supprimer cette note ?')) return;
  try {
    const res = await fetch(`/api/notes/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) { toast('Note supprimée', 'success'); setTimeout(() => location.reload(), 500); }
  } catch (e) { toast('Erreur', 'error'); }
}

// ============ BOOKMARKS ============
function openBookmarkModal() {
  document.getElementById('bookmarkModal').classList.add('open');
  document.getElementById('bmTitle').focus();
}

async function saveBookmark() {
  const title = document.getElementById('bmTitle').value.trim();
  const url = document.getElementById('bmUrl').value.trim();
  const category = document.getElementById('bmCategory').value.trim() || 'Général';
  if (!title || !url) { toast('Titre et URL requis', 'error'); return; }
  
  try {
    const res = await fetch('/api/bookmarks', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title, url, category })
    });
    const data = await res.json();
    if (data.success) {
      toast('Bookmark ajouté', 'success');
      closeModal('bookmarkModal');
      setTimeout(() => location.reload(), 500);
    } else {
      toast(data.errors?.[0]?.msg || 'Erreur', 'error');
    }
  } catch (e) { toast('Erreur réseau', 'error'); }
}

async function deleteBookmark(e, id) {
  e.preventDefault();
  e.stopPropagation();
  if (!confirm('Supprimer ce bookmark ?')) return;
  try {
    const res = await fetch(`/api/bookmarks/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) { toast('Bookmark supprimé', 'success'); setTimeout(() => location.reload(), 500); }
  } catch (e) { toast('Erreur', 'error'); }
}

// ============ UTILITAIRES ============
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
}

// Fermer modal en cliquant l'overlay
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) overlay.classList.remove('open');
  });
});

function toast(message, type = 'success') {
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.textContent = message;
  document.getElementById('toasts').appendChild(el);
  setTimeout(() => el.remove(), 3000);
}

// Init
refreshSystem();
// Actualisation auto système toutes les 30s
setInterval(refreshSystem, 30000);
</script>
</body>
</html>
