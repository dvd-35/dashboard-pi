<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Double authentification — Dashboard Pi</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0d1117; --surface: #161b22; --surface2: #1c2128; --border: #30363d;
      --text: #e6edf3; --muted: #8b949e;
      --accent: #58a6ff; --success: #3fb950; --danger: #f85149; --warning: #d29922;
    }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); }
    .layout { display: flex; min-height: 100vh; }
    .sidebar { width: 220px; background: var(--surface); border-right: 1px solid var(--border); padding: 1.5rem 1rem; flex-shrink: 0; display: flex; flex-direction: column; }
    .sidebar-logo { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem; }
    .sidebar-logo .icon { width: 32px; height: 32px; background: linear-gradient(135deg, var(--accent), #a371f7); border-radius: 8px; display: flex; align-items: center; justify-content: center; }
    .sidebar-logo span { font-weight: 700; }
    .nav-item { display: flex; align-items: center; gap: 0.625rem; padding: 0.5rem 0.75rem; border-radius: 6px; color: var(--muted); font-size: 0.875rem; text-decoration: none; transition: all 0.1s; margin-bottom: 0.25rem; cursor: pointer; background: none; border: none; width: 100%; }
    .nav-item:hover { background: var(--surface2); color: var(--text); }
    .nav-item.active { background: rgba(88,166,255,0.1); color: var(--accent); }
    .nav-spacer { flex: 1; }
    .main { flex: 1; padding: 2rem; max-width: 680px; }
    h1 { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.375rem; }
    .subtitle { color: var(--muted); font-size: 0.875rem; margin-bottom: 2rem; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
    .card-title { font-size: 0.9375rem; font-weight: 600; }
    .badge { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
    .badge-on { background: rgba(63,185,80,0.1); color: var(--success); border: 1px solid rgba(63,185,80,0.3); }
    .badge-off { background: rgba(139,148,158,0.1); color: var(--muted); border: 1px solid var(--border); }
    .alert { padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.875rem; margin-bottom: 1.5rem; }
    .alert-success { background: rgba(63,185,80,0.1); border: 1px solid rgba(63,185,80,0.3); color: var(--success); }
    .alert-error { background: rgba(248,81,73,0.1); border: 1px solid rgba(248,81,73,0.3); color: #ff7b72; }
    .alert-warning { background: rgba(210,153,34,0.1); border: 1px solid rgba(210,153,34,0.3); color: var(--warning); }
    p { font-size: 0.875rem; color: var(--muted); line-height: 1.6; }
    .how-it-works { display: flex; flex-direction: column; gap: 0.75rem; margin: 1.25rem 0; }
    .step { display: flex; gap: 0.875rem; align-items: flex-start; }
    .step-num { width: 28px; height: 28px; background: rgba(88,166,255,0.12); color: var(--accent); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8125rem; font-weight: 700; flex-shrink: 0; }
    .step-text { font-size: 0.8125rem; color: var(--muted); padding-top: 0.3rem; }
    .step-text strong { color: var(--text); }
    .email-box { display: flex; align-items: center; gap: 0.5rem; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 0.625rem 0.875rem; font-size: 0.875rem; color: var(--accent); margin: 1rem 0; }
    .btn { padding: 0.5rem 1.25rem; border-radius: 6px; font-size: 0.875rem; font-weight: 500; cursor: pointer; border: none; transition: all 0.15s; }
    .btn-primary { background: var(--accent); color: #0d1117; }
    .btn-primary:hover { background: #79c0ff; }
    .btn-danger { background: none; border: 1px solid var(--danger); color: var(--danger); }
    .btn-danger:hover { background: rgba(248,81,73,0.1); }
  </style>
</head>
<body>
<div class="layout">
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="icon">🖥️</div>
      <span>Dashboard Pi</span>
    </div>
    <a class="nav-item" href="/dashboard">📊 Dashboard</a>
    <a class="nav-item active" href="/admin/2fa">🔐 Double auth</a>
    <% if (locals.user && user.isAdmin) { %>
    <a class="nav-item" href="/admin/users">👥 Utilisateurs</a>
    <% } %>
    <div class="nav-spacer"></div>
    <form method="POST" action="/logout">
      <button type="submit" class="nav-item">🚪 Déconnexion</button>
    </form>
  </aside>

  <main class="main">
    <h1>Double authentification</h1>
    <p class="subtitle">Un code à usage unique vous sera envoyé par email à chaque connexion.</p>

    <% if (locals.success === 'enabled') { %>
    <div class="alert alert-success">✅ Double authentification activée ! Elle s'appliquera dès votre prochaine connexion.</div>
    <% } else if (locals.success === 'disabled') { %>
    <div class="alert alert-success">✅ Double authentification désactivée.</div>
    <% } %>
    <% if (locals.error === 'no_email') { %>
    <div class="alert alert-error">⚠️ Aucun email associé à votre compte. Contactez l'administrateur.</div>
    <% } %>

    <div class="card">
      <div class="card-header">
        <div class="card-title">Statut</div>
        <% if (locals.user2fa && user2fa.email_2fa_enabled) { %>
        <span class="badge badge-on">✅ Activée</span>
        <% } else { %>
        <span class="badge badge-off">○ Désactivée</span>
        <% } %>
      </div>

      <% if (locals.user2fa && user2fa.email) { %>
      <div class="email-box">📧 <span><%= user2fa.email %></span></div>
      <% } %>

      <div class="how-it-works">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-text">Vous entrez votre <strong>identifiant et mot de passe</strong></div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-text">Un <strong>code à 6 chiffres</strong> est envoyé sur votre email</div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-text">Vous entrez le code — <strong>valable 10 minutes</strong></div>
        </div>
      </div>

      <% if (locals.user2fa && user2fa.email_2fa_enabled) { %>
        <div class="alert alert-warning" style="margin-bottom:1rem;">
          ⚠️ Si vous désactivez le 2FA, votre compte sera protégé par votre mot de passe uniquement.
        </div>
        <form method="POST" action="/admin/2fa/toggle" onsubmit="return confirm('Désactiver le 2FA ?')">
          <button type="submit" class="btn btn-danger">Désactiver le 2FA</button>
        </form>
      <% } else { %>
        <form method="POST" action="/admin/2fa/toggle">
          <button type="submit" class="btn btn-primary">Activer le 2FA par email</button>
        </form>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
