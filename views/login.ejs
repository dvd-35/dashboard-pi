<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Connexion — Dashboard Pi</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0d1117; --surface: #161b22; --border: #30363d;
      --text: #e6edf3; --muted: #8b949e;
      --accent: #58a6ff; --accent2: #a371f7;
      --danger: #f85149; --warning: #d29922;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg); color: var(--text);
      min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 1rem;
    }
    body::before {
      content: ''; position: fixed; inset: 0;
      background-image: linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 40px 40px; opacity: 0.2; pointer-events: none;
    }
    .card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; padding: 2.5rem; width: 100%; max-width: 400px;
      box-shadow: 0 16px 48px rgba(0,0,0,0.5); position: relative;
    }
    .logo { text-align: center; margin-bottom: 2rem; }
    .logo-icon {
      width: 56px; height: 56px; margin: 0 auto 1rem;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;
    }
    .logo h1 { font-size: 1.25rem; font-weight: 600; }
    .logo p { font-size: 0.875rem; color: var(--muted); margin-top: 0.25rem; }
    .step-badge {
      display: inline-flex; align-items: center; gap: 0.375rem;
      background: rgba(88,166,255,0.1); color: var(--accent);
      border: 1px solid rgba(88,166,255,0.3);
      border-radius: 20px; font-size: 0.75rem; font-weight: 600;
      padding: 0.25rem 0.75rem; margin-top: 0.5rem;
    }
    .email-hint {
      background: rgba(88,166,255,0.06); border: 1px solid rgba(88,166,255,0.2);
      border-radius: 8px; padding: 0.75rem 1rem;
      font-size: 0.8125rem; color: var(--muted); margin-bottom: 1.5rem; text-align: center;
    }
    .email-hint strong { color: var(--accent); }
    .alert {
      padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.875rem;
      margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;
    }
    .alert-error { background: rgba(248,81,73,0.1); border: 1px solid rgba(248,81,73,0.3); color: #ff7b72; }
    .alert-warning { background: rgba(210,153,34,0.1); border: 1px solid rgba(210,153,34,0.3); color: var(--warning); }
    .form-group { margin-bottom: 1.25rem; }
    label { display: block; font-size: 0.875rem; font-weight: 500; color: var(--muted); margin-bottom: 0.5rem; }
    input {
      width: 100%; padding: 0.625rem 0.875rem;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 8px; color: var(--text); font-size: 0.9375rem;
      outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    }
    input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(88,166,255,0.15); }
    input::placeholder { color: #484f58; }
    input.code-input {
      font-size: 2rem; font-weight: 800; text-align: center;
      letter-spacing: 0.75rem; font-variant-numeric: tabular-nums; padding: 1rem;
    }
    button[type="submit"] {
      width: 100%; padding: 0.75rem; background: var(--accent); color: #0d1117;
      border: none; border-radius: 8px; font-size: 0.9375rem; font-weight: 600;
      cursor: pointer; transition: background 0.15s; margin-top: 0.5rem;
    }
    button[type="submit"]:hover:not(:disabled) { background: #79c0ff; }
    button[type="submit"]:disabled { opacity: 0.5; cursor: not-allowed; }
    .hint { font-size: 0.8125rem; color: var(--muted); text-align: center; margin-top: 0.75rem; }
    .back-link { display: block; text-align: center; margin-top: 1rem; font-size: 0.8125rem; color: var(--muted); text-decoration: none; }
    .back-link:hover { color: var(--text); }
    .footer { text-align: center; margin-top: 1.5rem; font-size: 0.8125rem; color: #484f58; }
  </style>
</head>
<body>
<div class="card">
  <div class="logo">
    <div class="logo-icon"><%= locals.step === '2fa' ? '📧' : '🖥️' %></div>
    <h1>Dashboard Pi</h1>
    <% if (locals.step === '2fa') { %>
      <p>Vérification par email</p>
      <div class="step-badge">🔒 Étape 2 sur 2</div>
    <% } else { %>
      <p>Connexion requise</p>
    <% } %>
  </div>

  <% if (locals.expired) { %>
  <div class="alert alert-warning"><span>⏱️</span><span>Session expirée. Reconnectez-vous.</span></div>
  <% } %>

  <% if (locals.error) { %>
  <div class="alert alert-error"><span>⚠️</span><span><%= error %></span></div>
  <% } %>

  <% if (!locals.blocked) { %>
    <% if (locals.step === '2fa') { %>

      <div class="email-hint">
        Un code à 6 chiffres a été envoyé à<br>
        <strong><%= locals.emailHint || '***' %></strong>
        <% if (locals.ttlMinutes) { %> — valable <strong><%= ttlMinutes %> min</strong><% } %>
      </div>

      <form method="POST" action="/login/2fa" id="loginForm" autocomplete="off">
        <div class="form-group">
          <label for="code">Code reçu par email</label>
          <input
            type="text" id="code" name="code"
            class="code-input"
            required minlength="6" maxlength="6"
            inputmode="numeric" pattern="[0-9]{6}"
            autocomplete="one-time-code"
            autofocus placeholder="000000"
          >
        </div>
        <button type="submit" id="submitBtn">Vérifier</button>
        <p class="hint">Vérifiez aussi vos spams si vous ne voyez pas l'email.</p>
      </form>
      <a class="back-link" href="/login">← Recommencer la connexion</a>

    <% } else { %>

      <form method="POST" action="/login" id="loginForm" autocomplete="on">
        <div class="form-group">
          <label for="username">Identifiant</label>
          <input type="text" id="username" name="username" required autocomplete="username" autofocus maxlength="50" placeholder="Votre identifiant">
        </div>
        <div class="form-group">
          <label for="password">Mot de passe</label>
          <input type="password" id="password" name="password" required autocomplete="current-password" maxlength="100" placeholder="••••••••">
        </div>
        <button type="submit" id="submitBtn">Se connecter</button>
      </form>

    <% } %>
  <% } %>

  <div class="footer">Accès privé — non autorisé</div>
</div>

<script>
  document.getElementById('loginForm')?.addEventListener('submit', function() {
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.textContent = 'Vérification...';
  });
  // Auto-submit dès 6 chiffres saisis
  document.getElementById('code')?.addEventListener('input', function() {
    if (this.value.replace(/\D/g, '').length === 6) {
      this.value = this.value.replace(/\D/g, '');
      document.getElementById('loginForm').requestSubmit();
    }
  });
</script>
</body>
</html>
