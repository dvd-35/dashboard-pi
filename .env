# ============================================
# CONFIGURATION — Copier en .env et remplir
# NE JAMAIS COMMITTER .env dans git !
# ============================================

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ── PostgreSQL ─────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dashboard_pi
DB_USER=dashboard_user
DB_PASSWORD=CHANGER_CE_MOT_DE_PASSE_FORT

# ── Session ────────────────────────────────
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGER_AVEC_VALEUR_ALEATOIRE_LONGUE
SESSION_MAX_AGE=28800000

# ── HTTPS ──────────────────────────────────
SSL_KEY=./certs/key.pem
SSL_CERT=./certs/cert.pem

# ── Email (2FA + invitations) ──────────────
# Gmail : créer un "Mot de passe d'application" sur
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ton.email@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# Adresse affichée comme expéditeur
SMTP_FROM="Dashboard Pi <ton.email@gmail.com>"

# ── Code 2FA ───────────────────────────────
# Durée de validité du code (en secondes) — 10 minutes
OTP_TTL=600

# ── Invitations ────────────────────────────
# Durée de validité du lien d'invitation (en heures)
INVITE_TTL_HOURS=48

# URL de base de l'app (pour les liens dans les emails)
APP_URL=https://localhost:3000

