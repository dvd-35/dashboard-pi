# ============================================
# CONFIGURATION - Copier en .env et remplir
# NE JAMAIS COMMITTER .env dans git !
# ============================================

# Environnement
NODE_ENV=production

# Serveur
PORT=3000
HOST=0.0.0.0

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dashboard_pi
DB_USER=dashboard_user
DB_PASSWORD=CHANGER_CE_MOT_DE_PASSE_FORT

# Sessions - Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGER_AVEC_UNE_VALEUR_ALEATOIRE_TRES_LONGUE

# Durée de session (en millisecondes) - 8 heures
SESSION_MAX_AGE=28800000

# Admin (créé au premier setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGER_MOT_DE_PASSE_ADMIN

# Météo (optionnel) - API OpenWeatherMap gratuite
WEATHER_API_KEY=
WEATHER_CITY=Paris
WEATHER_COUNTRY=FR
